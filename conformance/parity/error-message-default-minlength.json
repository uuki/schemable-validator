{
  "name": "default message: minLength plural (no override, BE/FE canonical parity)",
  "category": "parity",
  "schema": { "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object",
    "properties": { "f": { "type": "string", "minLength": 3 } }, "required": ["f"] },
  "input": { "f": "ab" },
  "expected": { "f": { "is_valid": false, "errors": ["must be at least 3 characters long"] } }
}
