{
  "name": "boolean field rejects arbitrary string 'maybe'",
  "category": "parity",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "subscribe": { "type": "boolean" }
    },
    "required": ["subscribe"]
  },
  "input": { "subscribe": "maybe" },
  "expected": {
    "subscribe": { "is_valid": false }
  }
}
