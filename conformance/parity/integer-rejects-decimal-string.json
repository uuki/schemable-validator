{
  "name": "integer field rejects decimal string '3.14'",
  "category": "parity",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "age": { "type": "integer" }
    },
    "required": ["age"]
  },
  "input": { "age": "3.14" },
  "expected": {
    "age": { "is_valid": false }
  }
}
