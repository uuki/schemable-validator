{
  "name": "required string field rejects empty value",
  "category": "parity",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "name": { "type": "string", "minLength": 1 }
    },
    "required": ["name"]
  },
  "input": { "name": "" },
  "expected": {
    "name": { "is_valid": false }
  }
}
