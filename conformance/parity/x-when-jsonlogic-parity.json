{
  "name": "x-when JSONLogic: conditional required field parity (=== literal)",
  "category": "parity",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "type":         { "type": "string" },
      "company_name": { "type": "string" }
    },
    "required": ["type"],
    "x-when": [
      {
        "condition": { "===": [{ "var": "type" }, "company"] },
        "require": ["company_name"]
      }
    ]
  },
  "input": { "type": "company", "company_name": "" },
  "expected": {
    "type":         { "is_valid": true },
    "company_name": { "is_valid": false }
  }
}
