{
  "name": "enum field accepts a listed value",
  "category": "structural",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "plan": { "type": "string", "enum": ["free", "pro"] }
    },
    "required": ["plan"]
  },
  "input": { "plan": "pro" },
  "expected": {
    "plan": { "is_valid": true }
  }
}
