{
  "name": "array field accepts items meeting item constraints",
  "category": "structural",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "tags": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "required": ["tags"]
  },
  "input": { "tags": ["php", "js"] },
  "expected": {
    "tags": { "is_valid": true }
  }
}
