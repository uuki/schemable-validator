{
  "name": "array field enforces minItems",
  "category": "structural",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "tags": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 2
      }
    },
    "required": ["tags"]
  },
  "input": { "tags": ["php"] },
  "expected": {
    "tags": { "is_valid": false }
  }
}
