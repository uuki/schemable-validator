{
  "name": "date format rejects a calendar-invalid date (Feb 30)",
  "category": "contract",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "date": { "type": "string", "format": "date" }
    },
    "required": ["date"]
  },
  "input": { "date": "2026-02-30" },
  "expected": {
    "date": { "is_valid": false }
  }
}
