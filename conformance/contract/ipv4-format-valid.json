{
  "name": "ipv4 format accepts a well-formed IPv4 address",
  "category": "contract",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "ip": { "type": "string", "format": "ipv4" }
    },
    "required": ["ip"]
  },
  "input": { "ip": "192.168.1.1" },
  "expected": {
    "ip": { "is_valid": true }
  }
}
