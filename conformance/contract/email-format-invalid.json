{
  "name": "email format rejects a malformed address",
  "category": "contract",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "email": { "type": "string", "format": "email" }
    },
    "required": ["email"]
  },
  "input": { "email": "not-an-email" },
  "expected": {
    "email": { "is_valid": false }
  }
}
