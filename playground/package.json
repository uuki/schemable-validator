{
  "name": "playground",
  "private": true,
  "type": "module",
  "scripts": {
    "predeps": "COMPOSER_MIRROR_PATH_REPOS=1 composer install --no-dev --working-dir=../packages/wp-schemable-validator",
    "predev": "pnpm run predeps",
    "dev": "wp-playground-cli start --path=../packages/wp-schemable-validator --port=9400 --blueprint=blueprint.json",
    "pretest:start": "pnpm run predeps",
    "test:start": "wp-playground-cli start --path=../packages/wp-schemable-validator --port=9400 --blueprint=blueprint.json --reset --skip-browser"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@wp-playground/cli": "*"
  }
}
