<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true">
  <testsuites>
    <testsuite name="Unit">
      <directory>packages/core/tests/Unit</directory>
    </testsuite>
    <testsuite name="Conformance">
      <directory>packages/core/tests/Conformance</directory>
    </testsuite>
  </testsuites>
  <coverage>
    <include>
      <directory suffix=".php">packages/core</directory>
    </include>
  </coverage>
</phpunit>
