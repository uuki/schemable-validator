{
  "name": "uuki/schemable-validator",
  "description": "Schema based validation plugin.",
  "type": "package",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "SchemableValidator\\": "packages/core/"
    },
    "files": [
      "packages/core/constants.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "SchemableValidator\\Tests\\": "packages/core/tests/"
    }
  },
  "require": {
    "php": ">=7.4",
    "respect/validation": "2.2.4",
    "symfony/polyfill-php80": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "opis/json-schema": "^2.6"
  },
  "suggest": {
    "opis/json-schema": "Enables OpisAdapter (strict JSON Schema 2020-12 backend). Not needed for the default Respect adapter or the dependency-free NativeAdapter."
  }
}
