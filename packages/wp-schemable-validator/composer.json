{
  "name": "uuki/schemable-validator-plugin",
  "type": "wordpress-plugin",
  "require": {
    "uuki/schemable-validator": "*"
  },
  "autoload": {
    "psr-4": {
      "SchemableValidator\\Interfaces\\WordPress\\": "src/Interfaces/WordPress/"
    },
    "files": [
      "src/Interfaces/WordPress/constants.php"
    ]
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../..",
      "options": {
        "symlink": false
      }
    }
  ],
  "minimum-stability": "dev"
}
