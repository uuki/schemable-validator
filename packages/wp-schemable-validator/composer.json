{
  "name": "uuki/schemable-validator-plugin",
  "type": "wordpress-plugin",
  "repositories": [
    {
      "type": "path",
      "url": "../core",
      "options": { "symlink": true }
    }
  ],
  "require": {
    "php": ">=7.4",
    "uuki/schemable-validator-core": "*@dev",
    "symfony/polyfill-php80": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "SchemableValidator\\Interfaces\\WordPress\\": "src/Interfaces/WordPress/"
    },
    "files": ["src/Interfaces/WordPress/constants.php"]
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "brain/monkey": "^2.6",
    "respect/validation": "2.2.4"
  }
}
