{
  "name": "@uuki/schemable-validator-client",
  "version": "0.21.0",
  "description": "Client-side validation library for schemable-validator JSON Schema output. No transport, no framework.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./zod": {
      "import": {
        "types": "./dist/adapters/zod.d.mts",
        "default": "./dist/adapters/zod.mjs"
      },
      "require": {
        "types": "./dist/adapters/zod.d.cts",
        "default": "./dist/adapters/zod.cjs"
      }
    },
    "./valibot": {
      "import": {
        "types": "./dist/adapters/valibot.d.mts",
        "default": "./dist/adapters/valibot.mjs"
      },
      "require": {
        "types": "./dist/adapters/valibot.d.cts",
        "default": "./dist/adapters/valibot.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && node scripts/postbuild.mjs && node scripts/sync-to-wp.mjs",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "peerDependencies": {
    "valibot": ">=1.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "valibot": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "valibot": "^1.4.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.8",
    "zod": "^4.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uuki/schemable-validator.git"
  },
  "homepage": "https://uuki.github.io/schemable-validator/",
  "publishConfig": {
    "access": "public"
  }
}
