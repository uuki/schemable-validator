{
  "name": "@schemable-validator/client",
  "version": "0.10.0",
  "description": "Client-side validation library for schemable-validator JSON Schema output. No transport, no framework.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && node scripts/postbuild.mjs && node scripts/sync-to-wp.mjs",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
