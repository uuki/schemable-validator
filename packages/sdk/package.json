{
  "name": "@schemable-validator/sdk",
  "version": "0.1.0",
  "description": "Pure validation SDK for schemable-validator JSON Schema output. No transport, no framework.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown && node scripts/postbuild.mjs && node scripts/sync-to-wp.mjs",
    "dev": "tsdown --watch"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.12.0",
    "typescript": "^5.5.0"
  }
}
